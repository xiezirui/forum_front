{"remainingRequest":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Computer Science\\Go\\forum\\forum_front\\src\\views\\Followers.vue?vue&type=style&index=0&id=7568ce6a&scoped=true&lang=css","dependencies":[{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\src\\views\\Followers.vue","mtime":1772959097912},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1772960217766},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1772960217548},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\postcss-loader\\src\\index.js","mtime":1772960217520},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js","mtime":1772960217465}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:Ci5uYXZJbmZvewogICAgZmxvYXQ6IHJpZ2h0OwogICAgZmxleDogYXV0bzsKfQo="},{"version":3,"sources":["Followers.vue"],"names":[],"mappings":";AA4KA;AACA;AACA;AACA","file":"Followers.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n    <div class=\"nk-container\">\r\n        <Navbar></Navbar>\r\n        <div class=\"main\">\r\n            <div class=\"container\">\r\n                <!--关注导航栏-->\r\n                <el-menu\r\n                        :default-active=\"activeIndex\"\r\n                        class=\"el-menu-demo\"\r\n                        mode=\"horizontal\"\r\n                        @select=\"handleSelect\"\r\n                        background-color=\"#545c64\"\r\n                        text-color=\"#fff\"\r\n                        active-text-color=\"#ffd04b\">\r\n                    <el-menu-item index=\"1\">\r\n                        <router-link class=\"text-primary\" :to=\"{name:'Followees',params:{userId:user.id}}\">\r\n                            <span v-text=\"user.username\"></span>\r\n                            关注的人\r\n                        </router-link>\r\n                    </el-menu-item>\r\n                    <el-menu-item index=\"2\"><span v-text=\"user.username\"></span>的粉丝</el-menu-item>\r\n                    <el-menu-item class=\"navInfo\">\r\n                        <router-link :to=\"{name: 'Profile' ,params: {uid : user.id}}\">\r\n                            返回主页\r\n                        </router-link>\r\n                    </el-menu-item>\r\n                </el-menu>\r\n                <div class=\"line\"></div>\r\n\r\n                <!-- 粉丝列表 -->\r\n                <ul class=\"list-unstyled\">\r\n                    <li class=\"media pb-3 pt-3 mb-3 border-bottom position-relative\" v-for=\" map in  userList\">\r\n                        <router-link :to=\"{name: 'Profile' ,params: {uid : map.user.id}}\">\r\n                            <el-avatar  :src=\"map.user.avatar\"></el-avatar>\r\n                        </router-link>\r\n\r\n                        <div class=\"media-body\">\r\n                            <h6 class=\"mt-0 mb-3\">\r\n                                <span class=\"text-success\" v-text=\"map.user.username\" >落基山脉下的闲人</span>\r\n                                <span class=\"float-right text-muted font-size-12\">\r\n\t\t\t\t\t\t\t\t\t关注于 <i v-text=\"map.followTime\" >2019-04-28 14:13:25</i>\r\n\t\t\t\t\t\t\t\t</span>\r\n                            </h6>\r\n                            <div>\r\n                                <button type=\"button\"  @click=\"follow(map.user.id)\" class=\"btn btn-info btn-sm float-right mr-5 follow-btn\" v-text=\"map.hasFollowed?'取消关注':'关注TA'\">关注TA</button>\r\n                            </div>\r\n                        </div>\r\n                    </li>\r\n                </ul>\r\n\r\n\r\n                <!--分页，@current-change会把点击的页数传给方法-->\r\n                <el-pagination class=\"mpage\"\r\n                               background\r\n                               layout=\"prev, pager, next\"\r\n                               :current-page=\"currentPage\"\r\n                               :page-size=\"pageSize\"\r\n                               :total=\"total\"\r\n                               @current-change=page>\r\n                </el-pagination>\r\n            </div>\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    import Navbar from \"../components/Navbar\";\r\n    export default {\r\n        name: \"Followers\",\r\n        components:{\r\n            Navbar\r\n        },\r\n        created() {\r\n\r\n            //请求用户主页信息\r\n            const _this = this;\r\n            console.log(this.$route.params.uid)\r\n            //请求页面资源\r\n            this.$axios({\r\n                method:'get',\r\n                url:'/followers/'+_this.$route.params.userId,\r\n            }).then(function(res){\r\n                if (res.data.code == 200){\r\n                    const myData = res.data.data;\r\n                    _this.user = myData.user;\r\n                    _this.userList = myData.userList;\r\n                    _this.total = myData.total;\r\n\r\n                }else{\r\n                    _this.fail(res.data.msg)\r\n                }\r\n                console.log(res);\r\n            }).catch(function(error){\r\n                console.log(error);\r\n            });\r\n        },\r\n        data(){\r\n            return{\r\n                activeIndex: '2',\r\n                user:'',\r\n                userList:'',\r\n                currentPage:1,\r\n                pageSize:5,\r\n                total:0,\r\n                uploadPath:this.$axios.defaults.baseURL\r\n\r\n            }\r\n        },\r\n        methods: {\r\n            handleSelect(key, keyPath) {\r\n                console.log(key, keyPath);\r\n            },\r\n            fail(msg) {\r\n                this.$message.error(msg);\r\n            },\r\n            page(currentPage) {\r\n                const _this = this\r\n                _this.$axios.get(\"/followers/\"+_this.$route.params.userId+\"?currentPage=\" + currentPage).then(res => {\r\n                    const myData = res.data.data;\r\n                    _this.user = myData.user;\r\n                    _this.userList = myData.userList;\r\n                    _this.total = myData.total;\r\n                    _this.currentPage = res.data.data.currentPage\r\n\r\n                })\r\n            },\r\n            follow(entityId){\r\n                const _this = this;\r\n                //要先登录才能关注或取消关注\r\n                if (!this.$store.state.isLogin || this.$store.state.isLogin==''){\r\n                    this.$message.error('要登录才能关注哦');\r\n                    return;\r\n                }\r\n                let path = '';\r\n                if (_this.hasFollowed){\r\n                    path = '/unfollow'\r\n                }else {\r\n                    path = '/follow'\r\n                }\r\n                this.$axios({\r\n                    method:'post',\r\n                    url:path,\r\n                    data:{\r\n                        entityType:3,\r\n                        entityId:entityId\r\n                    }\r\n                }).then(function(res){\r\n                    if (res.data.code == 200){\r\n                        const myData = res.data.data;\r\n                        console.log(myData)\r\n                        _this.followerCount = myData.followerCount\r\n                        _this.hasFollowed = myData.hasFollowed\r\n\r\n                    }else{\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n                    console.log(res);\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            }\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n    .navInfo{\r\n        float: right;\r\n        flex: auto;\r\n    }\r\n</style>"]}]}