nk\" :to=\"{name: 'Profile' ,params: {uid :user.id}}\">{{user.username}}的主页</router-link>\r\n                        </li>\r\n                        <li class=\"nav-item\">\r\n                            <a class=\"nav-link active\" href=\"javascript:;\">{{user.username}}的文章</a>\r\n                        </li>\r\n                        <li class=\"nav-item\">\r\n                            <router-link class=\"nav-link\" :to=\"{name:'Collection',params:{uid:user.id}}\" >{{user.username}}的收藏</router-link>\r\n                        </li>\r\n                    </ul>\r\n                </div>\r\n                <!-- 文章列表 -->\r\n                <div class=\"media mt-5\">\r\n                    <div class=\"media-body\">\r\n                        <ul class=\"list-unstyled\">\r\n                            <li class=\"media pb-3 pt-3 mb-3 border-bottom position-relative\" v-for=\"postVo in records\">\r\n\r\n                                <el-card>\r\n                                    <h4>\r\n                                        <!--跳转到另一个组件，带参数-->\r\n                                        <!--:to=\"{name: 'BlogDetail', params: {blogId: post.id}}-->\r\n                                        <!--跳转到另一个组件，带参数-->\r\n                                        <router-link :to=\"{name : 'PostDetail' , params: {pid:postVo.post.id}} \">\r\n                                            {{postVo.post.title}}\r\n                                        </router-link>\r\n                                        <span>发表于{{postVo.post.createTimeStr}}</span>\r\n                                    </h4>\r\n\r\n                                    <div class=\"p_tag\">\r\n                                        <el-tag v-show=\"postVo.post.type == 1\" type=\"danger\" effect=\"dark\">置顶</el-tag>\r\n                                        <el-tag v-show=\"postVo.post.status == 1\" type=\"''\" effect=\"dark\">精选</el-tag>\r\n                                        <span v-text=\"postVo.post.likeCount\"></span>赞\r\n                                    </div>\r\n                                </el-card>\r\n\r\n                            </li>\r\n                        </ul>\r\n                    </div>\r\n                </div>\r\n\r\n                <!--分页，@current-change会把点击的页数传给方法-->\r\n                <el-pagination class=\"mpage\"\r\n                               background\r\n                               layout=\"prev, pager, next\"\r\n                               :current-page=\"currentPage\"\r\n                               :page-size=\"pageSize\"\r\n                               :total=\"total\"\r\n                               @current-change=page>\r\n                </el-pagination>\r\n            </div>\r\n\r\n\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    import Navbar from \"../components/Navbar\";\r\n    export default {\r\n        name: \"UserPosts\",\r\n        components:{\r\n            Navbar\r\n        },\r\n        data(){\r\n            return{\r\n                uploadPath:this.$axios.defaults.baseURL,\r\n                records: {},\r\n                currentPage: 1,\r\n                total: 0,\r\n                pageSize: 5,\r\n\r\n                user:{},\r\n\r\n            }\r\n        },\r\n        //頁面首先加載第一頁\r\n        created() {\r\n            const _this = this\r\n            _this.$axios.get('/user/userPost/+'+_this.$route.params.uid).then(res => {\r\n                console.log(res)\r\n                _this.records = res.data.data.pagination.records\r\n                _this.currentPage = res.data.data.pagination.currentPage\r\n                _this.total = res.data.data.pagination.total\r\n                _this.pageSize = res.data.data.pagination.pageSize\r\n                _this.user = res.data.data.user\r\n\r\n            })\r\n        },\r\n        methods:{\r\n            page(currentPage) {\r\n                const _this = this;\r\n                //要先登录才能关注或取消关注\r\n\r\n                this.$axios({\r\n                    method:'get',\r\n                    url:'/user/userPost/'+_this.$route.params.uid+'?currentPage='+currentPage\r\n                }).then(function(res){\r\n                    if (res.data.code == 200){\r\n                        const myData = res.data.data;\r\n                        console.log(myData)\r\n                        _this.records = res.data.data.pagination.records\r\n                        _this.currentPage = res.data.data.pagination.currentPage\r\n                        _this.total = res.data.data.pagination.total\r\n                        _this.pageSize = res.data.data.pagination.pageSize\r\n                    }else{\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n                    console.log(res);\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            }\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAqEA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACA;MACAC,UAAA,OAAAC,MAAA,CAAAC,QAAA,CAAAC,OAAA;MACAC,OAAA;MACAC,WAAA;MACAC,KAAA;MACAC,QAAA;MAEAC,IAAA;IAEA;EACA;EACA;EACAC,QAAA;IACA,MAAAC,KAAA;IACAA,KAAA,CAAAT,MAAA,CAAAU,GAAA,sBAAAD,KAAA,CAAAE,MAAA,CAAAC,MAAA,CAAAC,GAAA,EAAAC,IAAA,CAAAC,GAAA;MACAC,OAAA,CAAAC,GAAA,CAAAF,GAAA;MACAN,KAAA,CAAAN,OAAA,GAAAY,GAAA,CAAAjB,IAAA,CAAAA,IAAA,CAAAoB,UAAA,CAAAf,OAAA;MACAM,KAAA,CAAAL,WAAA,GAAAW,GAAA,CAAAjB,IAAA,CAAAA,IAAA,CAAAoB,UAAA,CAAAd,WAAA;MACAK,KAAA,CAAAJ,KAAA,GAAAU,GAAA,CAAAjB,IAAA,CAAAA,IAAA,CAAAoB,UAAA,CAAAb,KAAA;MACAI,KAAA,CAAAH,QAAA,GAAAS,GAAA,CAAAjB,IAAA,CAAAA,IAAA,CAAAoB,UAAA,CAAAZ,QAAA;MACAG,KAAA,CAAAF,IAAA,GAAAQ,GAAA,CAAAjB,IAAA,CAAAA,IAAA,CAAAS,IAAA;IAEA;EACA;EACAY,OAAA;IACAC,KAAAhB,WAAA;MACA,MAAAK,KAAA;MACA;;MAEA,KAAAT,MAAA;QACAqB,MAAA;QACAC,GAAA,sBAAAb,KAAA,CAAAE,MAAA,CAAAC,MAAA,CAAAC,GAAA,qBAAAT;MACA,GAAAU,IAAA,WAAAC,GAAA;QACA,IAAAA,GAAA,CAAAjB,IAAA,CAAAyB,IAAA;UACA,MAAAC,MAAA,GAA