stVo.user.username\"></span>\r\n                        </router-link>\r\n                        <h4>\r\n                            <!--跳转到另一个组件，带参数-->\r\n                            <!--:to=\"{name: 'BlogDetail', params: {blogId: post.id}}-->\r\n                            <!--跳转到另一个组件，带参数-->\r\n                           <router-link :to=\"{name : 'PostDetail' , params: {pid:postVo.post.id}} \">\r\n                                {{postVo.post.title}}\r\n                            </router-link>\r\n                        </h4>\r\n\r\n                        <div class=\"p_tag\">\r\n                            <el-tag v-show=\"postVo.post.type == 1\" type=\"danger\" effect=\"dark\">置顶</el-tag>\r\n                            <el-tag v-show=\"postVo.post.status == 1\" type=\"''\" effect=\"dark\">精选</el-tag>\r\n                            <span v-text=\"postVo.post.likeCount\"></span>赞\r\n                        </div>\r\n                        <p>{{postVo.post.content}}</p>\r\n\r\n\r\n                    </el-card>\r\n\r\n                </el-timeline-item>\r\n\r\n            </el-timeline>\r\n\r\n            <!--分页，@current-change会把点击的页数传给方法-->\r\n            <el-pagination class=\"mpage\"\r\n                           background\r\n                           layout=\"prev, pager, next\"\r\n                           :current-page=\"currentPage\"\r\n                           :page-size=\"pageSize\"\r\n                           :total=\"total\"\r\n                           @current-change=page>\r\n            </el-pagination>\r\n\r\n        </div>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    import Navbar from \"../components/Navbar\";\r\n    export default {\r\n        name: \"Index\",\r\n        components:{\r\n            navbar : Navbar\r\n        },\r\n        data(){\r\n            return{\r\n                uploadPath:this.$axios.defaults.baseURL,\r\n                records: {},\r\n                currentPage: 1,\r\n                total: 0,\r\n                pageSize: 5\r\n            }\r\n        },\r\n        methods:{\r\n            page(currentPage) {\r\n                const _this = this\r\n                _this.$axios.get(\"/post/list?currentPage=\" + currentPage).then(res => {\r\n                    console.log(res)\r\n                    _this.records = res.data.data.records\r\n                    _this.currentPage = res.data.data.currentPage\r\n                    _this.total = res.data.data.total\r\n                    _this.pageSize = res.data.data.pageSize\r\n                })\r\n            }\r\n        },\r\n        //頁面首先加載第一頁\r\n        created() {\r\n            const _this = this\r\n            _this.$axios.get(\"/post/list?currentPage=1\").then(res => {\r\n                _this.records = res.data.data.records\r\n                _this.currentPage = res.data.data.currentPage\r\n                _this.total = res.data.data.total\r\n                _this.pageSize = res.data.data.pageSize\r\n            })\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n    .mpage {\r\n        margin: 0 auto;\r\n        text-align: center;\r\n\r\n    }\r\n    .plist{\r\n        margin-top: 10px;\r\n    }\r\n    .p_tag{\r\n        float: right;\r\n        margin-bottom: 10px;\r\n    }\r\n</style>"],"mappings":"AAmDA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAC,MAAA,EAAAH;EACA;EACAI,KAAA;IACA;MACAC,UAAA,OAAAC,MAAA,CAAAC,QAAA,CAAAC,OAAA;MACAC,OAAA;MACAC,WAAA;MACAC,KAAA;MACAC,QAAA;IACA;EACA;EACAC,OAAA;IACAC,KAAAJ,WAAA;MACA,MAAAK,KAAA;MACAA,KAAA,CAAAT,MAAA,CAAAU,GAAA,6BAAAN,WAAA,EAAAO,IAAA,CAAAC,GAAA;QACAC,OAAA,CAAAC,GAAA,CAAAF,GAAA;QACAH,KAAA,CAAAN,OAAA,GAAAS,GAAA,CAAAd,IAAA,CAAAA,IAAA,CAAAK,OAAA;QACAM,KAAA,CAAAL,WAAA,GAAAQ,GAAA,CAAAd,IAAA,CAAAA,IAAA,CAAAM,WAAA;QACAK,KAAA,CAAAJ,KAAA,GAAAO,GAAA,CAAAd,IAAA,CAAAA,IAAA,CAAAO,KAAA;QACAI,KAAA,CAAAH,QAAA,GAAAM,GAAA,CAAAd,IAAA,CAAAA,IAAA,CAAAQ,QAAA;MACA;IACA;EACA;EACA;EACAS,QAAA;IACA,MAAAN,KAAA;IACAA,KAAA,CAAAT,MAAA,CAAAU,GAAA,6BAAAC,IAAA,CAAAC,GAAA;MACAH,KA