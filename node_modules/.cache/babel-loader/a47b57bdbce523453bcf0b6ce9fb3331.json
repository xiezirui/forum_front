xt=\"msgVo.fromUser.username\"></span>\r\n                        </router-link>\r\n                        <router-link :to=\"{name : 'PostDetail' , params: {pid:msgVo.postId}} \">\r\n                            <h4>关注了你</h4>\r\n                        </router-link>\r\n\r\n                    </el-card>\r\n\r\n                </el-timeline-item>\r\n\r\n            </el-timeline>\r\n\r\n            <!--分页，@current-change会把点击的页数传给方法-->\r\n            <el-pagination class=\"mpage\"\r\n                           background\r\n                           layout=\"prev, pager, next\"\r\n                           :current-page=\"currentPage\"\r\n                           :page-size=\"pageSize\"\r\n                           :total=\"total\"\r\n                           @current-change=page>\r\n            </el-pagination>\r\n\r\n        </div>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    export default {\r\n        name: \"FollowMe\",\r\n        data(){\r\n            return{\r\n                currentPage : 1,\r\n                pageSize:5,\r\n                msgVos:{},\r\n                total:0\r\n            }\r\n        },\r\n        methods:{\r\n            //弹出登录成功信息\r\n            success(msg) {\r\n                this.$message({\r\n                    message: msg,\r\n                    type: 'success'\r\n                });\r\n            },\r\n            fail(msg) {\r\n                this.$message.error(msg);\r\n            },\r\n            page(currentPage) {\r\n                const _this = this\r\n                _this.$axios.get(\"/message/follow?currentPage=\" + currentPage).then(res => {\r\n                    if (res.data.code!=200){\r\n                        _this.fail(res.data.msg);\r\n                        return;\r\n                    }else {\r\n                        const data = res.data.data;\r\n                        _this.msgVos = data.msgVos;\r\n                        _this.total = data.total;\r\n                    }\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                    _this.fail(\"网络故障\")\r\n                });\r\n            }\r\n\r\n        },\r\n        created() {\r\n            const _this = this;\r\n            //提交表单\r\n            this.$axios({\r\n                method:'get',\r\n                url:'/message/follow',\r\n            }).then(function(res){\r\n                if (res.data.code!=200){\r\n                    _this.fail(res.data.msg);\r\n                    return;\r\n                }else {\r\n                    const data = res.data.data;\r\n                    _this.msgVos = data.msgVos;\r\n                    _this.total = data.total;\r\n\r\n                }\r\n\r\n            }).catch(function(error){\r\n                console.log(error);\r\n            });\r\n\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAoCA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MACAC,QAAA;MACAC,MAAA;MACAC,KAAA;IACA;EACA;EACAC,OAAA;IACA;IACAC,QAAAC,GAAA;MACA,KAAAC,QAAA;QACAC,OAAA,EAAAF,GAAA;QACAG,IAAA;MACA;IACA;IACAC,KAAAJ,GAAA;MACA,KAAAC,QAAA,CAAAI,KAAA,CAAAL,GAAA;IACA;IACAM,KAAAZ,WAAA;MACA,MAAAa,KAAA;MACAA,KAAA,CAAAC,MAAA,CAAAC,GAAA,kCAAAf,WAAA,EAAAgB,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAlB,IAAA,CAAAmB,IAAA;UACAL,KAAA,CAAAH,IAAA,CAAAO,GAAA,CAAAlB,IAAA,CAAAO,GAAA;UACA;QACA;UACA,MAAAP,IAAA,GAAAkB,GAAA,CAAAlB,IAAA,CAAAA,IAAA;UACAc,KAAA,CAAAX,MAAA,GAAAH,IAAA,CAAAG,MAAA;UACAW,KAAA,CAAAV,KAAA,GAAAJ,IAAA,CAAAI,KAAA;QACA;MACA,GAAAgB,KAAA,WAAAR,KAAA;QACAS,OAAA,CAAAC,GAAA,CAAAV,KAAA;QACAE,KAAA,CAAAH,IAAA;MACA;IACA;EAEA;EACAY,QAAA;IACA,MAAAT,KAAA;IACA;IACA,KAAAC,MAAA;MACAS,MAAA;MACAC,GAAA;IACA,GAAAR,IAAA,WAAAC,GAAA;MACA,IAAAA,GAAA,CAAAlB,IAAA,CAAAmB,IAAA;QACAL,KAAA,CAAAH,IAAA,CAAAO,GAAA,CAAAlB,IAAA,CAAAO,GAAA;QACA;MACA;QACA,MAAAP,IAAA,GAAAkB,GAAA,CAAAlB,IAAA,CAAAA,IAAA;QACAc,KAAA,CAAAX,MAAA,GAAAH,IAAA,CAAAG,MAAA;QACAW,KAAA,CAAAV,KAAA,GAAAJ,IAAA,CAAAI,KAAA;MAEA;IAEA,GAAAgB,KAAA,WAAAR,KAAA;MACAS,OAA