           url: '/notice/detail/' + _this.topic\r\n            }).then(function (res) {\r\n                let myData = res.data.data;\r\n                console.log(myData);\r\n                _this.notices = myData.notices;\r\n                _this.total = myData.total;\r\n                _this.currentPage = myData.currentPage;\r\n\r\n            }).catch(function (error) {\r\n                console.log(error);\r\n            });\r\n        },\r\n        data(){\r\n            return{\r\n                notices:'',\r\n                currentPage:1,\r\n                pageSize:5,\r\n                total:0,\r\n                uploadPath:this.$axios.defaults.baseURL,\r\n                topic:''\r\n            }\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":";AAsEA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,OAAA;IACAC,KAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IACAC,KAAAC,WAAA;MACA,MAAAC,KAAA;MACAA,KAAA,CAAAC,MAAA,CAAAC,GAAA,qBAAAF,KAAA,CAAAG,KAAA,qBAAAJ,WAAA,EAAAK,IAAA,CAAAC,GAAA;QACA,MAAAC,MAAA,GAAAD,GAAA,CAAAE,IAAA,CAAAA,IAAA;QAEAP,KAAA,CAAAQ,OAAA,GAAAF,MAAA,CAAAE,OAAA;QACAR,KAAA,CAAAS,KAAA,GAAAH,MAAA,CAAAG,KAAA;QACAT,KAAA,CAAAD,WAAA,GAAAO,MAAA,CAAAP,WAAA;MACA;IACA;EACA;EACAW,OAAA,WAAAA,CAAA;IACA,MAAAV,KAAA;IACAA,KAAA,CAAAG,KAAA,GAAAH,KAAA,CAAAW,MAAA,CAAAC,MAAA,CAAAT,KAAA;IACA;IACA,KAAAF,MAAA;MACAY,MAAA;MACAC,GAAA,sBAAAd,KAAA,CAAAG;IACA,GAAAC,IAAA,WAAAC,GAAA;MACA,IAAAC,MAAA,GAAAD,GAAA,CAAAE,IAAA,CAAAA,IAAA;MACAQ,OAAA,CAAAC,GAAA,CAAAV,MAAA;MACAN,KAAA,CAAAQ,OAAA,GAAAF,MAAA,CAAAE,OAAA;MACAR,KAAA,CAAAS,KAAA,GAAAH,MAAA,CAAAG,KAAA;MACAT,KAAA,CAAAD,WAAA,GAAAO,MAAA,CAAAP,WAAA;IAEA,GAAAkB,KAAA,WAAAC,KAAA;MACAH,OAAA,CAAAC,GAAA,CAAAE,KAAA;IACA;EACA;EACAX,KAAA;IACA;MACAC,OAAA;MACAT,WAAA;MACAoB,QAAA;MACAV,KAAA;MACAW,UAAA,OAAAnB,MAAA,CAAAoB,QAAA,CAAAC,OAAA;MACAnB,KAAA;IACA;EACA;AACA","ignoreList":[]}]}