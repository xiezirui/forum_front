{"remainingRequest":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\babel-loader\\lib\\index.js!D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Computer Science\\Go\\forum\\forum_front\\src\\components\\Navbar.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\src\\components\\Navbar.vue","mtime":1772959097891},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\babel.config.js","mtime":1772959097882},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\babel-loader\\lib\\index.js","mtime":1772960218707},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js","mtime":1772960217465}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["name","props","activeIndex","type","String","default","required","created","data","picturePath","uploadPath","$axios","defaults","baseURL","isLogin","$store","state","userInfo","keyword","msgCount","methods","handleSelect","key","keyPath","console","log","toMessage","$message","error","$router","push","login","register","logout","commit","publish","flag","path","toIndex","toHome","_this","$route","fullPath","params","uid","id","toHot","search","toSetting","toCollect","toUserPost","toKen"],"sources":["src/components/Navbar.vue"],"sourcesContent":["<template>\r\n    <div class=\"navbar\">\r\n        <el-menu :default-active=\"activeIndex\" class=\"el-menu-demo myMenu\" mode=\"horizontal\" @select=\"handleSelect\" >\r\n            <el-menu-item index=\"0\" @click=\"toKen\">\r\n                关于本站</el-menu-item>\r\n<!--            <el-menu-item index=\"1\">首页</el-menu-item>-->\r\n            <el-menu-item index=\"2\" @click=\"toIndex\">最新</el-menu-item>\r\n            <el-menu-item index=\"3\" @click=\"toHot\">最热</el-menu-item>\r\n            <el-menu-item index=\"4\" @click=\"toMessage\">消息中心<span v-if=\"msgCount != 0\" class=\"badge badge-danger ml-3\">{{msgCount}}</span></el-menu-item>\r\n            <el-menu-item >\r\n                <el-input class=\"border-radius\" @keyup.enter=\"search\" v-model=\"keyword\"></el-input>\r\n                <el-button type=\"primary\" @click=\"search\"  icon=\"el-icon-search\">搜索</el-button>\r\n            </el-menu-item>\r\n\r\n\r\n            <el-menu-item @click=\"login\"  v-show =\"!$store.state.isLogin\" class=\"navInfo\">登录</el-menu-item>\r\n            <el-menu-item @click=\"register\" v-show=\"!$store.state.isLogin\" class=\"navInfo\">注册</el-menu-item>\r\n\r\n            <el-submenu v-show=\"$store.state.isLogin\"  index=\"5\" class=\"navInfo\">\r\n                <template slot=\"title\" >创建</template>\r\n                <el-menu-item index=\"5-2\" @click=\"publish(1)\">写文章</el-menu-item>\r\n            </el-submenu>\r\n\r\n            <!--头像-->\r\n            <el-submenu v-show=\"$store.state.isLogin\"  index=\"6\" class=\"navInfo\">\r\n                <el-menu-item v-text=\"$store.state.userInfo.username\"></el-menu-item>\r\n                <template slot=\"title\" >\r\n                    <el-avatar :size=\"50\" :src=\"$store.state.userInfo.avatar\"></el-avatar>\r\n                </template>\r\n                <el-menu-item index=\"6-1\" @click=\"toHome\">我的主页</el-menu-item>\r\n                <el-menu-item index=\"6-2\" @click=\"toSetting\">设置</el-menu-item>\r\n                <el-menu-item index=\"6-2\" @click=\"toCollect\">我的收藏</el-menu-item>\r\n                <el-menu-item index=\"6-3\" @click=\"toUserPost\">我的文章</el-menu-item>\r\n                <el-menu-item index=\"6-4\" @click=\"logout\">退出登录</el-menu-item>\r\n            </el-submenu>\r\n\r\n        </el-menu>\r\n        <div class=\"line\"></div>\r\n\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    export default {\r\n        name: 'Navbar',\r\n        props: {\r\n            activeIndex: {\r\n                type: String,\r\n                default: '2',\r\n                required: false //在使用组件不一定传值\r\n            }\r\n        },\r\n        created() {\r\n        },\r\n        data() {\r\n            return {\r\n                picturePath:'http://localhost:8089',\r\n                // picturePath:'http://47.115.88.155',\r\n                uploadPath:this.$axios.defaults.baseURL,\r\n                isLogin : this.$store.state.isLogin,\r\n                // activeIndex: '2',\r\n                userInfo:this.$store.state.userInfo,\r\n                keyword:'',\r\n                msgCount:0\r\n            };\r\n        },\r\n        methods: {\r\n            handleSelect(key, keyPath) {\r\n                console.log(key, keyPath);\r\n            },\r\n            toMessage(){\r\n                if (!this.$store.state.isLogin || this.$store.state.isLogin==''){\r\n                    this.$message.error('要登录才能查看消息哦');\r\n                    return;\r\n                }\r\n                //跳转到消息中心\r\n                this.$router.push('/message')\r\n            },\r\n            login(){\r\n                this.$router.push('/login')\r\n            },\r\n            register(){\r\n                this.$router.push('/register')\r\n            },\r\n            logout(){\r\n                this.$store.commit(\"logout\");\r\n            },\r\n            //跳转至发表文章页面，传递参数tag\r\n            publish(flag){\r\n                if (flag == 0){\r\n                    this.$router.push({\r\n                        path :'/post/query',\r\n                    });\r\n                }else{\r\n                    this.$router.push({\r\n                        path :'/post/add',\r\n                    });\r\n                }\r\n\r\n            },\r\n            toIndex(){\r\n                this.$router.push(\"/\");\r\n            },\r\n            toHome(){\r\n                const  _this = this;\r\n                console.log(_this.$route.fullPath)\r\n                 console.log(_this.$route.path)\r\n\r\n                this.$router.push({\r\n                    name :'Profile',\r\n                    params:{\r\n                        uid:_this.$store.state.userInfo.id\r\n                    }\r\n                });\r\n            },\r\n            toHot(){\r\n                this.$router.push({\r\n                    name :'Hot'\r\n                });\r\n            },\r\n            search(){\r\n                const  _this = this;\r\n\r\n                    this.$router.push({\r\n                        name: 'Search',\r\n                        params: {\r\n                            keyword:_this.keyword\r\n                        }\r\n                    });\r\n            },\r\n            toSetting(){\r\n                this.$router.push('/setting')\r\n            },\r\n            toCollect(){\r\n                const _this = this\r\n                this.$router.push({\r\n                    name: 'Collection',\r\n                    params: {\r\n                        uid:_this.$store.state.userInfo.id\r\n                    }\r\n                });\r\n            },\r\n            toUserPost(){\r\n                const _this = this\r\n                this.$router.push({\r\n                    name: 'UserPosts',\r\n                    params: {\r\n                        uid:_this.$store.state.userInfo.id\r\n                    }\r\n                });\r\n            },\r\n            toKen(){\r\n                this.$router.push('/ken')\r\n            }\r\n\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n    .navInfo{\r\n        float: right;\r\n        flex: auto;\r\n    }\r\n    .myMenu{\r\n        width: 100%;\r\n    }\r\n</style>"],"mapping