{"remainingRequest":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\babel-loader\\lib\\index.js!D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Computer Science\\Go\\forum\\forum_front\\src\\views\\PostDetail.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\src\\views\\PostDetail.vue","mtime":1772959097920},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\babel.config.js","mtime":1772959097882},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\babel-loader\\lib\\index.js","mtime":1772960218707},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js","mtime":1772960217465}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["Navbar","name","components","data","postVo","postContent","comments","uploadPath","$axios","defaults","baseURL","picturePath","pictures","entityType","entityId","commentUid","targetId","replyContent","commentContent","likeStatus","collectStatus","currentPage","total","pageSize","created","_this","method","url","$route","params","pid","then","res","MardownIt","require","md","render","post","content","commentCount","catch","error","console","log","methods","fail","msg","$message","commentPost","length","postId","status","message","type","$router","go","replyTwo","$store","state","isLogin","alert","ReplyData","rId","rUid","page","records","like","event","entityUserId","code","myData","likeCount","firstChild","lastChild","innerHTML","setTop","get","id","setWonder","setDelete","push","collect","path","user","collectCount"],"sources":["src/views/PostDetail.vue"],"sourcesContent":["<template>\r\n    <div class=\"nk-container\">\r\n        <!-- 头部 -->\r\n        <Navbar></Navbar>\r\n\r\n\r\n        <div class=\"main\">\r\n\r\n            <!--帖子内容-->\r\n            <div class=\"container\">\r\n                <!--帖子标题-->\r\n                <h3 class=\"mb-4\">\r\n                    <span v-text=\"postVo.post.title\"></span>\r\n                    <div class=\"float-right\">\r\n                        <button v-if=\"this.$store.state.isLogin\" type=\"button\" class=\"btn btn-danger btn-sm\" id=\"topBtn\"\r\n                                :disabled=\"postVo.post.type==1\" @click=\"setTop\">置顶</button>\r\n                        <button v-if=\"this.$store.state.isLogin\" type=\"button\" class=\"btn btn-danger btn-sm\" id=\"wonderfulBtn\"\r\n                                :disabled=\"postVo.post.status==1\" @click=\"setWonder\">加精</button>\r\n                        <button v-if=\"this.$store.state.isLogin\" type=\"button\" class=\"btn btn-danger btn-sm\" id=\"deleteBtn\"\r\n                                :disabled=\"postVo.post.status==2\" @click=\"setDelete\">删除</button>\r\n                    </div>\r\n                </h3>\r\n\r\n                <!-- 作者 -->\r\n                <div class=\"media pb-3 border-bottom\">\r\n                    <!--用户头像-->\r\n                    <router-link :to=\"{name: 'Profile' ,params: {uid : postVo.user.id}}\">\r\n                        <el-avatar  :src=\"postVo.user.avatar\"></el-avatar>\r\n                    </router-link>\r\n\r\n\r\n                    <div class=\"media-body\">\r\n                        <!--用户名-->\r\n                        <router-link :to=\"{name: 'Profile' ,params: {uid : postVo.user.id}}\">\r\n                            <div class=\"mt-0 text-warning\" v-text=\"postVo.user.username\"></div>\r\n                        </router-link>\r\n                        <div class=\"text-muted mt-3\">\r\n                            发布于 <b v-text=\"postVo.post.createTimeStr\"></b>\r\n                            <ul class=\"d-inline float-right\">\r\n                                <li class=\"d-inline ml-2\" @click=\"collect(postVo.post.id)\">\r\n                                    <a href=\"javascript:;\">\r\n                                        <b v-text=\"collectStatus == 0 ? '收藏 ':'取消收藏 '\"></b>\r\n                                        <i v-text=\"postVo.post.collectCount\"></i>\r\n                                    </a>\r\n                                </li>\r\n                                <li class=\"d-inline ml-2\">|</li>\r\n                                <li class=\"d-inline ml-2\" @click=\"like($event.currentTarget,1,postVo.post.id,postVo.post.userId,postVo.post.id)\">\r\n                                    <a href=\"javascript:;\">\r\n                                        <b v-text=\"likeStatus == 0 ? '赞 ':'已赞 '\"></b>\r\n                                        <i v-text=\"postVo.post.likeCount\"></i>\r\n                                    </a>\r\n                                </li>\r\n                                <li class=\"d-inline ml-2\">|</li>\r\n                                <li class=\"d-inline ml-2\">回帖 <i v-text=\"postVo.post.commentCount\"></i></li>\r\n                            </ul>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n                <!-- 正文 -->\r\n<!--                <div class=\"mt-4 mb-3 content \" v-text=\"postVo.post.content\"></div>-->\r\n                <div class=\"markdown-body\" v-html=\"postContent\"></div>\r\n\r\n\r\n                <!--&lt;!&ndash;展示图片&ndash;&gt;\r\n                <div>\r\n                    <div class=\"block\" v-for=\"p in pictures\">\r\n                        <el-image :src=\"picturePath+p\"></el-image>\r\n                    </div>\r\n                </div>-->\r\n\r\n                <br>\r\n                <hr>\r\n\r\n            </div>\r\n\r\n            <!--评论列表-->\r\n            <div class=\"container mt-3\">\r\n\r\n                <!-- 回帖数量 -->\r\n                <div class=\"row\">\r\n                    <div class=\"col-8\">\r\n                        <h6><b class=\"square\"></b> <i v-text=\"postVo.post.commentCount\"></i>条回帖</h6>\r\n                    </div>\r\n                </div>\r\n\r\n                <!-- 回帖列表 -->\r\n                <ul class=\"list-unstyled mt-4\">\r\n                    <!--一级评论列表-->\r\n                    <li class=\"media pb-3 pt-3 mb-3 border-bottom\" v-for=\"commentVo in comments\">\r\n\r\n                        <!--用户头像-->\r\n                        <router-link :to=\"{name: 'Profile' ,params: {uid : commentVo.user.id}}\">\r\n                            <el-avatar  :src=\"commentVo.user.avatar\"></el-avatar>\r\n                        </router-link>\r\n\r\n                        <div class=\"media-body\">\r\n                            <div class=\"mt-0\">\r\n                                <!--用户名-->\r\n                                <router-link :to=\"{name: 'Profile' ,params: {uid : commentVo.user.id}}\">\r\n                                    <span class=\"font-size-12 text-success\" v-text=\"commentVo.user.username\"></span>\r\n                                </router-link>\r\n                            </div>\r\n                            <!--评论内容-->\r\n                            <div class=\"mt-2\" v-text=\"commentVo.comment.content\">\r\n                            </div>\r\n                            <div class=\"mt-4 text-muted font-size-12\">\r\n                                <!--发布时间-->\r\n                                <span>发布于 <b v-text=\"commentVo.comment.createTime\"></b></span>\r\n                                <ul class=\"d-inline float-right\">\r\n                                    <!--点赞-->\r\n                                    <li class=\"d-inline ml-2\" @click=\"like($event.currentTarget,2,commentVo.comment.id,commentVo.user.id,postVo.post.id)\">\r\n                                        <a href=\"javascript:;\">\r\n                                            <b v-text=\"commentVo.comment.likeStatus == 0 ? '赞 ':'已赞 '\"></b>\r\n                                            <i v-text=\"commentVo.comment.likeCount\"></i>\r\n                                        </a>\r\n                                    </li>\r\n                                    <li class=\"d-inline ml-2\">|</li>\r\n                                    <!--评论一级评论-->\r\n                                    <li class=\"d-inline ml-2\">\r\n                                        <!--第1个参数是entityId，第2个参数是targetId-->\r\n                                        <a v-b-toggle=\"'myReply'+commentVo.comment.id\" @click=\"ReplyData(commentVo.comment.id,0)\" class=\"m-1\">\r\n                                            回复(<i v-text=\"commentVo.replyCount\"></i>)\r\n                                        </a>\r\n                                    </li>\r\n                                </ul>\r\n                            </div>\r\n                            <!-- 二级评论列表 -->\r\n                            <ul class=\"list-unstyled mt-4 bg-gray p-3 font-size-12 text-muted\">\r\n\r\n                                <li class=\"pb-3 pt-3 mb-3 border-bottom\" v-for=\"replyVo in commentVo.replies\">\r\n                                    <div>\r\n\t\t\t\t\t\t\t\t\t\t<span v-if=\"replyVo.target == null\">\r\n                                            <router-link :to=\"{name: 'Profile' ,params: {uid : replyVo.user.id}}\">\r\n\t\t\t\t\t\t\t\t\t\t\t    <b class=\"text-info\" v-text=\"replyVo.user.username\"></b>:&nbsp;&nbsp;\r\n                                            </router-link>\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                        <span v-else>\r\n\t\t\t\t\t\t\t\t\t\t\t<i class=\"text-info\" v-text=\"replyVo.user.username\"></i> 回复\r\n\t\t\t\t\t\t\t\t\t\t\t<b class=\"text-info\" v-text=\"replyVo.target.username\"></b>:&nbsp;&nbsp;\r\n\t\t\t\t\t\t\t\t\t\t</span>\r\n                                        <!--回复内容-->\r\n                                        <span v-text=\"replyVo.reply.content\"></span>\r\n                                    </div>\r\n                                    <div class=\"mt-3\">\r\n                                        <!--回复时间-->\r\n                                        <span v-text=\"replyVo.reply.createTime\"></span>\r\n                                        <ul class=\"d-inline float-right\">\r\n                                            <!--点赞-->\r\n                                            <li class=\"d-inline ml-2\" @click=\"like($event.currentTarget,2,replyVo.reply.id,replyVo.user.id,postVo.post.id)\">\r\n                                                <a href=\"javascript:;\">\r\n                                                    <b v-text=\"replyVo.reply.likeStatus == 0 ? '赞 ':'已赞 '\"></b>\r\n                                                    <i v-text=\"replyVo.reply.likeCount\"></i>\r\n                                                </a>\r\n                                            </li>\r\n                                            <li class=\"d-inline ml-2\">|</li>\r\n                                            <!--回复二级评论-->\r\n                                            <li class=\"d-inline ml-2\">\r\n                                                <!--第1个参数是entityId，第2个参数是targetId-->\r\n                                                <a v-b-toggle=\"'myReply'+commentVo.comment.id\" @click=\"ReplyData(commentVo.comment.id,replyVo.user.id)\" class=\"m-1\">回复</a>\r\n                                            </li>\r\n                                        </ul>\r\n                                    </div>\r\n\r\n                                </li>\r\n\r\n                                <!-- 回复输入框 -->\r\n                                <b-collapse  :id=\"'myReply'+commentVo.comment.id\">\r\n                                    <li class=\"pb-3 pt-3\">\r\n                                        <div>\r\n                                            <input style=\"width: 55%\" type=\"text\" placeholder=\"回复字数不可超过100\" class=\"input-size\" v-model=\"replyContent\" />\r\n                                        </div>\r\n                                        <div class=\"text-lg-center mt-2\">\r\n                                            <button type=\"submit\" class=\"btn btn-primary btn-sm\" @click=\"replyTwo\" >&nbsp;&nbsp;回&nbsp;&nbsp;复&nbsp;&nbsp;</button>\r\n                                        </div>\r\n                                    </li>\r\n                                </b-collapse>\r\n\r\n                            </ul>\r\n                        </div>\r\n                    </li>\r\n                </ul>\r\n\r\n            </div>\r\n\r\n            <!--分页，@current-change会把点击的页数传给方法-->\r\n            <el-pagination class=\"mpage\"\r\n                           background\r\n                           layout=\"prev, pager, next\"\r\n                           :current-page=\"currentPage\"\r\n                           :page-size=\"pageSize\"\r\n                           :total=\"total\"\r\n                           @current-change=page>\r\n            </el-pagination>\r\n\r\n\r\n            <!-- 回帖输入 -->\r\n            <div class=\"myComment\">\r\n                    <p>\r\n                        <textarea class=\"CommentInput\"   placeholder=\"在这里畅所欲言你的看法吧,评论字数不可超过100\" v-model=\"commentContent\"></textarea>\r\n                    </p>\r\n                    <p >\r\n                        <button type=\"submit\" class=\"btn btn-primary btn-sm\" @click=\"commentPost()\">&nbsp;&nbsp;回&nbsp;&nbsp;帖&nbsp;&nbsp;</button>\r\n                    </p>\r\n            </div>\r\n\r\n\r\n        </div><!--main 的div结束-->\r\n    </div>\r\n\r\n\r\n</template>\r\n\r\n<script>\r\n    import 'github-markdown-css/github-markdown.css'\r\n    import Navbar from \"../components/Navbar\";\r\n    export default {\r\n        name: \"PostDetail\",\r\n        components:{\r\n            Navbar\r\n        },\r\n        data(){\r\n            return{\r\n                postVo:{},\r\n                postContent:{},\r\n                comments:{},\r\n                uploadPath:this.$axios.defaults.baseURL,\r\n                picturePath:'http://127.0.0.1',\r\n                // picturePath:'http://47.115.88.155',\r\n                pictures:{},\r\n\r\n                entityType:'',\r\n                entityId:'',\r\n                commentUid:'',\r\n                targetId:'',\r\n                replyContent:'',\r\n                commentContent:'',\r\n\r\n                //帖子点赞状态\r\n                likeStatus:0,\r\n                collectStatus:0,\r\n\r\n\r\n                //分页数据\r\n                currentPage: 1,\r\n                total: 0,\r\n                pageSize: 5\r\n            }\r\n        },\r\n        created() {\r\n            const _this = this;\r\n            //提交表单\r\n            this.$axios({\r\n                method:'get',\r\n                url:'/post/detail/'+this.$route.params.pid,\r\n            }).then(function(res){\r\n                _this.postVo = res.data.data.postVo;\r\n\r\n                //渲染成md效果\r\n                var MardownIt = require(\"markdown-it\");\r\n                var md = new MardownIt();\r\n                _this.postContent = md.render(_this.postVo.post.content);\r\n\r\n                _this.comments = res.data.data.comments;\r\n                _this.pictures = res.data.data.pictures;\r\n                _this.likeStatus = res.data.data.likeStatus;\r\n                _this.collectStatus = res.data.data.collectStatus;\r\n                //分页数据\r\n                _this.total=res.data.data.postVo.post.commentCount\r\n            }).catch(function(error){\r\n                console.log(error);\r\n            });\r\n        },\r\n        methods:{\r\n            fail(msg) {\r\n                this.$message.error(msg);\r\n            },\r\n            //评论帖子\r\n            commentPost(){\r\n                if (this.commentContent.length > 100){\r\n                    this.fail(\"评论字数不可超过100！\");\r\n                    return;\r\n                }\r\n                const _this = this;\r\n                this.$axios({\r\n                    method:'post',\r\n                    url:'/comment/add',\r\n                    data:{\r\n                        entityType:1,\r\n                        entityId:this.$route.params.pid,\r\n                        targetId:0,\r\n                        content:this.commentContent,\r\n                        postId:this.$route.params.pid\r\n                    }\r\n                }).then(function(res){\r\n                    _this.commentContent = \"\";\r\n                    console.log(res)\r\n                    if (res.status == 200){\r\n                        _this.$message({\r\n                            message: res.data.msg,\r\n                            type: 'success'\r\n                        });\r\n                        //刷新页面\r\n                        _this.$router.go(0);\r\n                    }\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            },\r\n\r\n            //回复二级评论\r\n            replyTwo(){\r\n                if (this.replyContent.length > 100){\r\n                    this.fail(\"回复字数不可超过100！\");\r\n                    return;\r\n                }\r\n                const _this = this;\r\n                if (this.$store.state.isLogin){\r\n                    this.$axios({\r\n                        method:'post',\r\n                        url:'/comment/add',\r\n                        data:{\r\n                            entityType:2,\r\n                            entityId:_this.entityId,\r\n                            targetId:_this.targetId,\r\n                            content:_this.replyContent,\r\n                            postId:this.$route.params.pid\r\n                        }\r\n                    }).then(function(res){\r\n                        _this.replyContent = \"\";\r\n                        if (res.status == 200){\r\n                            _this.$message({\r\n                                message: res.data.msg,\r\n                                type: 'success'\r\n                            });\r\n                            //刷新页面\r\n                            _this.$router.go(0);\r\n                        }\r\n                    }).catch(function(error){\r\n                        console.log(error);\r\n                    });\r\n                }else {\r\n                    alert(\"您尚未登录，不能回复！\");\r\n                }\r\n            },\r\n            //确定被回复对象\r\n            //第1个参数是entityId，第2个参数是targetId\r\n            ReplyData(rId,rUid){\r\n                this.entityId = rId;\r\n                this.targetId = rUid;\r\n            },\r\n            //评论分页\r\n            page(currentPage) {\r\n                const _this = this;\r\n                this.$axios({\r\n                    method:'post',\r\n                    url:'/post/comment/list',\r\n                    data:{\r\n                        currentPage:currentPage,\r\n                        pid:this.$route.params.pid\r\n                    }\r\n                }).then(function(res){\r\n                    _this.comments = res.data.data.records;\r\n                    _this.currentPage = res.data.data.currentPage\r\n                    _this.total = res.data.data.total\r\n\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            },\r\n            //点赞（$event.currentTarget传递的是dom元素本身）\r\n            like(event,entityType, entityId,entityUserId,postId){\r\n                if (!this.$store.state.isLogin || this.$store.state.isLogin==''){\r\n                    this.$message.error('要登录才能点赞哦');\r\n                    return;\r\n                }\r\n                //发送请求\r\n                let _this = this;\r\n                console.log(event);\r\n\r\n                this.$axios({\r\n                    method:'post',\r\n                    url:'/like',\r\n                    data:{\r\n                        entityType:entityType,\r\n                        entityId:entityId,\r\n                        entityUserId:entityUserId,\r\n                        postId:postId\r\n                    }\r\n                }).then(function(res){\r\n                    if (res.data.code == 200){\r\n                        const myData = res.data.data;\r\n                        console.log(myData)\r\n                        //更新帖子点赞数\r\n                        if (myData.entityType == 1){\r\n                            _this.postVo.post.likeCount = myData.likeCount\r\n                            _this.likeStatus = myData.likeStatus\r\n                        }else {\r\n                            //更新评论点赞数（直接操作dom元素）\r\n                            event.firstChild.lastChild.innerHTML= myData.likeCount\r\n                        }\r\n\r\n\r\n                    }else{\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            },\r\n            //置顶\r\n            setTop(){\r\n                const _this = this;\r\n                _this.$axios.get(\"/post/top?id=\"+_this.postVo.post.id).then(res => {\r\n                    console.log(res)\r\n                    if (res.data.code == 200){\r\n                        _this.postVo.post.type = 1;\r\n                    }else {\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n                })\r\n            },\r\n            //精选\r\n            setWonder(){\r\n                const _this = this;\r\n                _this.$axios.get(\"/post/wonderful?id=\"+_this.postVo.post.id).then(res => {\r\n                    console.log(res)\r\n                    if (res.data.code == 200){\r\n                        _this.postVo.post.status = 1;\r\n                    }else {\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n                })\r\n            },\r\n            //删除\r\n            setDelete(){\r\n                const _this = this;\r\n                _this.$axios.get(\"/post/delete?id=\"+_this.postVo.post.id).then(res => {\r\n                    if (res.data.code != 200){\r\n                        _this.fail(res.data.msg)\r\n                    }else{\r\n                        _this.$router.push(\"/\");\r\n                    }\r\n                })\r\n            },\r\n            //收藏\r\n            collect(pid){\r\n                if (!this.$store.state.isLogin || this.$store.state.isLogin==''){\r\n                    this.$message.error('要登录才能收藏哦');\r\n                    return;\r\n                }\r\n                //发送请求\r\n                let _this = this;\r\n                let path = '';\r\n                if (_this.collectStatus == 0){\r\n                    path = '/collect'\r\n                }else {\r\n                    path = '/uncollect'\r\n                }\r\n\r\n                this.$axios({\r\n                    method:'post',\r\n                    url:path,\r\n                    data:{\r\n                        entityId:pid,\r\n                        entityUserId:_this.postVo.user.id\r\n                    }\r\n                }).then(function(res){\r\n                    if (res.data.code == 200){\r\n                        const myData = res.data.data;\r\n                        console.log(myData)\r\n                        //更新帖子收藏数\r\n                        _this.postVo.post.collectCount = myData.collectCount\r\n                        _this.collectStatus = myData.collectStatus\r\n                    }else{\r\n                        _this.fai