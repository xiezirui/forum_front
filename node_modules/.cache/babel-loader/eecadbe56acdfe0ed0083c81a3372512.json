{"remainingRequest":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\babel-loader\\lib\\index.js!D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\Computer Science\\Go\\forum\\forum_front\\src\\views\\Collection.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\src\\views\\Collection.vue","mtime":1772959097910},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\babel.config.js","mtime":1772959097882},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\babel-loader\\lib\\index.js","mtime":1772960218707},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772960218700},{"path":"D:\\Computer Science\\Go\\forum\\forum_front\\node_modules\\vue-loader\\lib\\index.js","mtime":1772960217465}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["Navbar","name","components","created","_this","$axios","method","url","$route","params","uid","then","res","data","code","myData","console","log","user","total","posts","currentPage","fail","msg","catch","error","pageSize","uploadPath","defaults","baseURL","methods","$message","page"],"sources":["src/views/Collection.vue"],"sourcesContent":["<template>\r\n    <div  class=\"nk-container\">\r\n        <Navbar active-index=\"8\"></Navbar>\r\n\r\n\r\n        <!-- 内容 -->\r\n        <div class=\"main\">\r\n            <div class=\"container\">\r\n                <!-- 选项 -->\r\n                <div class=\"position-relative\">\r\n                    <ul class=\"nav nav-tabs\">\r\n                        <li class=\"nav-item\">\r\n                            <router-link class=\"nav-link\" :to=\"{name: 'Profile' ,params: {uid :user.id}}\">{{user.username}}的主页</router-link>\r\n                        </li>\r\n                        <li class=\"nav-item\">\r\n                            <router-link class=\"nav-link\" :to=\"{name: 'UserPosts' ,params: {uid :user.id}}\">{{user.username}}的文章</router-link>\r\n                        </li>\r\n                        <li class=\"nav-item \" >\r\n                            <a class=\"nav-link active \" href=\"javascript:;\">{{user.username}}的收藏</a>\r\n                        </li>\r\n                    </ul>\r\n                </div>\r\n\r\n                <ul class=\"list-unstyled\">\r\n                    <li class=\"media pb-3 pt-3 mb-3 border-bottom position-relative\" v-for=\" postVo in  posts\">\r\n\r\n                        <el-card>\r\n\r\n                            <h4>\r\n                                <!--跳转到另一个组件，带参数-->\r\n                                <!--:to=\"{name: 'BlogDetail', params: {blogId: post.id}}-->\r\n                                <!--跳转到另一个组件，带参数-->\r\n                                <router-link :to=\"{name : 'PostDetail' , params: {pid:postVo.post.id}} \">\r\n                                    {{postVo.post.title}}\r\n                                </router-link>\r\n                                <span>收藏于{{postVo.collectTime}}</span>\r\n                            </h4>\r\n\r\n                            <div class=\"p_tag\">\r\n                                <el-tag v-show=\"postVo.post.type == 1\" type=\"danger\" effect=\"dark\">置顶</el-tag>\r\n                                <el-tag v-show=\"postVo.post.status == 1\" type=\"''\" effect=\"dark\">精选</el-tag>\r\n                                <span v-text=\"postVo.post.likeCount\"></span>赞\r\n                            </div>\r\n\r\n                        </el-card>\r\n                    </li>\r\n                </ul>\r\n\r\n                <!--分页，@current-change会把点击的页数传给方法-->\r\n                <el-pagination class=\"mpage\"\r\n                               background\r\n                               layout=\"prev, pager, next\"\r\n                               :current-page=\"currentPage\"\r\n                               :page-size=\"pageSize\"\r\n                               :total=\"total\"\r\n                               @current-change=page>\r\n                </el-pagination>\r\n            </div>\r\n\r\n\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    import Navbar from \"../components/Navbar\";\r\n    export default {\r\n        name: \"Collection\",\r\n        components:{\r\n            Navbar\r\n        },\r\n        created() {\r\n            const _this = this;\r\n            //要先登录才能关注或取消关注\r\n\r\n            this.$axios({\r\n                method:'get',\r\n                url:'/collection/'+_this.$route.params.uid\r\n            }).then(function(res){\r\n                if (res.data.code == 200){\r\n                    const myData = res.data.data;\r\n                    console.log(myData)\r\n                    _this.user = myData.user\r\n                    _this.total = myData.total\r\n                    _this.posts = myData.posts\r\n                    _this.currentPage = myData.currentPage\r\n\r\n                }else{\r\n                    _this.fail(res.data.msg)\r\n                }\r\n                console.log(res);\r\n            }).catch(function(error){\r\n                console.log(error);\r\n            });\r\n        },\r\n        data(){\r\n            return{\r\n                user:{},\r\n                total:0,\r\n                posts:{},\r\n                currentPage:1,\r\n                pageSize:5,\r\n\r\n                uploadPath:this.$axios.defaults.baseURL\r\n            }\r\n        },\r\n        methods:{\r\n            fail(msg) {\r\n                this.$message.error(msg);\r\n            },\r\n            page(currentPage) {\r\n                const _this = this;\r\n                //要先登录才能关注或取消关注\r\n\r\n                this.$axios({\r\n                    method:'get',\r\n                    url:'/collection/'+_this.$route.params.uid+'?currentPage='+currentPage\r\n                }).then(function(res){\r\n                    if (res.data.code == 200){\r\n                        const myData = res.data.data;\r\n                        console.log(myData)\r\n                        _this.posts = myData.posts\r\n                        _this.currentPage = myData.currentPage\r\n\r\n                    }else{\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n                    console.log(res);\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            },\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAkEA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,QAAA;IACA,MAAAC,KAAA;IACA;;IAEA,KAAAC,MAAA;MACAC,MAAA;MACAC,GAAA,mBAAAH,KAAA,CAAAI,MAAA,CAAAC,MAAA,CAAAC;IACA,GAAAC,IAAA,WAAAC,GAAA;MACA,IAAAA,GAAA,CAAAC,IAAA,CAAAC,IAAA;QACA,MAAAC,MAAA,GAAAH,GAAA,CAAAC,IAAA,CAAAA,IAAA;QACAG,OAAA,CAAAC,GAAA,CAAAF,MAAA;QACAX,KAAA,CAAAc,IAAA,GAAAH,MAAA,CAAAG,IAAA;QACAd,KAAA,CAAAe,KAAA,GAAAJ,MAAA,CAAAI,KAAA;QACAf,KAAA,CAAAgB,KAAA,GAAAL,MAAA,CAAAK,KAAA;QACAhB,KAAA,CAAAiB,WAAA,GAAAN,MAAA,CAAAM,WAAA;MAEA;QACAjB,KAAA,CAAAkB,IAAA,CAAAV,GAAA,CAAAC,IAAA,CAAAU,GAAA;MACA;MACAP,OAAA,CAAAC,GAAA,CAAAL,GAAA;IACA,GAAAY,KAAA,WAAAC,KAAA;MACAT,OAAA,CAAAC,GAAA,CAAAQ,KAAA;IACA;EACA;EACAZ,KAAA;IACA;MACAK,IAAA;MACAC,KAAA;MACAC,KAAA;MACAC,WAAA;MACAK,QAAA;MAEAC,UAAA,OAAAtB,MAAA,CAAAuB,QAAA,CAAAC;IACA;EACA;EACAC,OAAA;IACAR,KAAAC,GAAA;MACA,KAAAQ,QAAA,CAAAN,KAAA,CAAAF,GAAA;IACA;IACAS,KAAAX,WAAA;MACA,MAAAjB,KAAA;MACA;;MAEA,KAAAC,MAAA;QACAC,MAAA;QACAC,GAAA,mBAAAH,KAAA,CAAAI,MAAA,CAAAC,MAAA,CAAAC,GAAA,qBAAAW;MACA,GAAAV,IAAA,WAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,IAAA,CAAAC,IAAA;UACA,MAAAC,MAAA,GAAAH,GAAA,CAAAC,IAAA,CAAAA,IAAA;UACAG,OAAA,CAAAC,GAAA,CAAAF,MAAA;UACAX,K