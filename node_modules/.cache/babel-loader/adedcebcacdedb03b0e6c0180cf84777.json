ser.id} \" class=\"my_li\">\r\n                        <div style=\"display: flex;justify-content: space-between\">\r\n                            <div>\r\n                                    <el-avatar class=\"u_avatar\"\r\n                                              :src=\"item.avatar\"\r\n                                              :alt=\"item.username\">\r\n                                        <div slot=\"error\" class=\"image-slot\">\r\n                                            <i class=\"el-icon-picture-outline\"></i>\r\n                                        </div>\r\n                                    </el-avatar>\r\n                                <p class=\"u_name\">{{item.username}}</p>\r\n                            </div>\r\n                        </div>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n\r\n            <div class=\"col-9\" >\r\n                <div class=\"w-100 chatbox\">\r\n                    <h2>与【{{currentUser.username}}】的聊天</h2>\r\n                    <hr>\r\n                    <!--消息列表-->\r\n                    <div >\r\n                        <ul class=\"list\" v-scroll-bar>\r\n                            <div v-if=\"currentUser!=null&&currentUser.id!=0\" v-for=\"item in sessions[this.userInfo.id+'_'+this.currentUser.id]\">\r\n                                <div v-if=\"item.fromId === userInfo.id\">\r\n                                    <own-msg-item :own-url=\"userInfo.avatar\"\r\n                                                  :msg-text=\"item.content\"\r\n                                                  :profile-id=\"userInfo.id\"\r\n                                                  :item=\"item\"\r\n                                                  style=\"float: right\"\r\n                                    ></own-msg-item >\r\n                                </div>\r\n                                <div v-else>\r\n                                    <opposite-msg-item :opposite-url=\"currentUser.avatar\"\r\n                                                       :msg-text=\"item.content\"\r\n                                                       :profile-id=\"currentUser.id\"\r\n                                                       :item=\"item\"\r\n                                                       style=\"float:left;\"\r\n                                    ></opposite-msg-item>\r\n                                </div>\r\n                            </div>\r\n                        </ul>\r\n\r\n                    </div>\r\n                    <!--输入框-->\r\n                    <div class=\"msg-enter\">\r\n                        <el-input\r\n                                resize=\"none\"\r\n                                class=\"msg-input\"\r\n                                type=\"textarea\"\r\n                                :show-word-limit=\"true\"\r\n                                :size=\"'20'\"\r\n                                title=\"输入内容请在20字以内。\"\r\n                                :autosize=\"{ minRows: 4, maxRows: 4}\"\r\n                                placeholder=\"请输入内容\"\r\n                                v-model=\"input_content\">\r\n                        </el-input>\r\n                        <el-button @click.native=\"sendMsg\" type=\"warning\" class=\"send-msg-btn\" round>发送</el-button>\r\n                    </div>\r\n<!--                </div>-->\r\n\r\n\r\n            </div>\r\n\r\n        </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!--测试滚动条-->\r\n<!--    <div class=\"list\" v-scroll-bar>-->\r\n<!--        <ul>-->\r\n<!--            <li v-for=\"item in testSesstion\">-->\r\n<!--                {{item.content}}-->\r\n<!--            </li>-->\r\n<!--        </ul>-->\r\n<!--    </div>-->\r\n</template>\r\n\r\n<script>\r\n    import {mapState} from \"vuex\";\r\n    import OppositeMsgItem from \"../chat/OppositeMsgItem\";\r\n    import OwnMsgItem from \"../chat/OwnMsgItem\";\r\n    export default {\r\n        name: \"ChatMe\",\r\n        components:{\r\n            OppositeMsgItem,\r\n            OwnMsgItem\r\n        },\r\n        data() {\r\n            const _this = this;\r\n            return {\r\n                userList: _this.$store.state.userList,\r\n                currentUser: _this.$store.state.currentUser,\r\n                input_content:''\r\n            }\r\n        },\r\n\r\n        methods:{\r\n            //改变当前聊天对象\r\n            changeCurrentUser(user){\r\n                this.currentUser = user;\r\n                //获取与currentUser的私聊记录\r\n                this.$store.commit('getSession',user.id)\r\n            },\r\n            //发送消息\r\n            sendMsg(){\r\n                let mesObj = new Object();\r\n                mesObj.content = this.input_content;\r\n                mesObj.toId=this.currentUser.id;\r\n                mesObj.fromId=this.userInfo.id;\r\n                mesObj.createTime = new Date();\r\n                //提交私聊消息记录（保存到本地）\r\n                this.$store.commit('addMessage',mesObj);\r\n                //发送消息到服务端\r\n                this.$store.state.ws.send(JSON.stringify(mesObj));\r\n                //清空输入框\r\n                this.input_content = '';\r\n\r\n\r\n            }\r\n        },\r\n        created() {\r\n        },\r\n        computed:mapState([\r\n            'sessions',\r\n            'currentSession',\r\n            'userInfo'\r\n        ]),\r\n\r\n    }\r\n</script>\r\n\r\n\r\n<style  scoped>\r\n\r\n\r\n    .my_li {\r\n        padding: 12px 15px;\r\n        border-bottom: 1px solid #292C33;\r\n        cursor: pointer\r\n    }\r\n    li_active {/*注意这个是.不是冒号:*/\r\n        background-color: rgba(255, 255, 255, 0.1);\r\n    }\r\n    .u_avatar {\r\n        border-radius: 2px;\r\n        width: 30px;\r\n        height: 30px;\r\n        vertical-align: middle;\r\n    }\r\n    .u_name {\r\n        display: inline-block;\r\n        margin-left: 15px;\r\n    }\r\n\r\n\r\n    .list{\r\n        position: relative;\r\n        height: 350px;\r\n        padding-left: 0px;\r\n    }\r\n\r\n    .send-msg-btn{\r\n        margin-top: 5px;\r\n        float: right;\r\n    }\r\n    .chatbox{\r\n        border-left: 1px slategray dashed;\r\n    }\r\n\r\n</style>\r\n\r\n"],"mappings":";AAuFA,SAAAA,QAAA;AACA,OAAAC,eAAA;AACA,OAAAC,UAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAH,eAAA;IACAC;EACA;EACAG,KAAA;IACA,MAAAC,KAAA;IACA;MACAC,QAAA,EAAAD,KAAA,CAAAE,MAAA,CAAAC,KAAA,CAAAF,QAAA;MACAG,WAAA,EAAAJ,KAAA,CAAAE,MAAA,CAAAC,KAAA,CAAAC,WAAA;MACAC,aAAA;IACA;EACA;EAEAC,OAAA;IACA;IACAC,kBAAAC,IAAA;MACA,KAAAJ,WAAA,GAAAI,IAAA;MACA;MACA,KAAAN,MAAA,CAAAO,MAAA,eAAAD,IAAA,CAAAE,EAAA;IACA;IACA;IACAC,QAAA;MACA,IAAAC,MAAA,OAAAC,MAAA;MACAD,MAAA,CAAAE,OAAA,QAAAT,aAAA;MACAO,MAAA,CAAAG,IAAA,QAAAX,WAAA,CAAAM,EAAA;MACAE,MAAA,CAAAI,MAAA,QAAAC,QAAA,CAAAP,EAAA;MACAE,MAAA,CAAAM,UAAA,OAAAC,IAAA;MACA;MACA,KAAAjB,MAAA,CAAAO,MAAA,eAAAG,MAAA;MACA;MACA,KAAAV,MAAA,CAAAC,KAAA,CAAAiB,EAAA,CAAAC,IAAA,CAAAC,IAAA,CAAAC,SAAA,CAAAX,MAAA;MACA;MACA,KAAAP,aAAA;IAGA;EACA;EACAmB,QAAA,GACA;EACAC,QAAA,EAAA/B,QAAA,EACA,YACA,kBACA,WACA;AAEA","ignoreList":[]}]}