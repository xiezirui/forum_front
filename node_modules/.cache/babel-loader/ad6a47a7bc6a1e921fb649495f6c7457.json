ss=\"el-menu-demo\"\r\n                        mode=\"horizontal\"\r\n                        @select=\"handleSelect\"\r\n                        background-color=\"#545c64\"\r\n                        text-color=\"#fff\"\r\n                        active-text-color=\"#ffd04b\">\r\n                    <el-menu-item index=\"1\">\r\n                        <router-link class=\"text-primary\" :to=\"{name:'Followees',params:{userId:user.id}}\">\r\n                            <span v-text=\"user.username\"></span>\r\n                            关注的人\r\n                        </router-link>\r\n                    </el-menu-item>\r\n                    <el-menu-item index=\"2\"><span v-text=\"user.username\"></span>的粉丝</el-menu-item>\r\n                    <el-menu-item class=\"navInfo\">\r\n                        <router-link :to=\"{name: 'Profile' ,params: {uid : user.id}}\">\r\n                            返回主页\r\n                        </router-link>\r\n                    </el-menu-item>\r\n                </el-menu>\r\n                <div class=\"line\"></div>\r\n\r\n                <!-- 粉丝列表 -->\r\n                <ul class=\"list-unstyled\">\r\n                    <li class=\"media pb-3 pt-3 mb-3 border-bottom position-relative\" v-for=\" map in  userList\">\r\n                        <router-link :to=\"{name: 'Profile' ,params: {uid : map.user.id}}\">\r\n                            <el-avatar  :src=\"map.user.avatar\"></el-avatar>\r\n                        </router-link>\r\n\r\n                        <div class=\"media-body\">\r\n                            <h6 class=\"mt-0 mb-3\">\r\n                                <span class=\"text-success\" v-text=\"map.user.username\" >落基山脉下的闲人</span>\r\n                                <span class=\"float-right text-muted font-size-12\">\r\n\t\t\t\t\t\t\t\t\t关注于 <i v-text=\"map.followTime\" >2019-04-28 14:13:25</i>\r\n\t\t\t\t\t\t\t\t</span>\r\n                            </h6>\r\n                            <div>\r\n                                <button type=\"button\"  @click=\"follow(map.user.id)\" class=\"btn btn-info btn-sm float-right mr-5 follow-btn\" v-text=\"map.hasFollowed?'取消关注':'关注TA'\">关注TA</button>\r\n                            </div>\r\n                        </div>\r\n                    </li>\r\n                </ul>\r\n\r\n\r\n                <!--分页，@current-change会把点击的页数传给方法-->\r\n                <el-pagination class=\"mpage\"\r\n                               background\r\n                               layout=\"prev, pager, next\"\r\n                               :current-page=\"currentPage\"\r\n                               :page-size=\"pageSize\"\r\n                               :total=\"total\"\r\n                               @current-change=page>\r\n                </el-pagination>\r\n            </div>\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n\r\n<script>\r\n    import Navbar from \"../components/Navbar\";\r\n    export default {\r\n        name: \"Followers\",\r\n        components:{\r\n            Navbar\r\n        },\r\n        created() {\r\n\r\n            //请求用户主页信息\r\n            const _this = this;\r\n            console.log(this.$route.params.uid)\r\n            //请求页面资源\r\n            this.$axios({\r\n                method:'get',\r\n                url:'/followers/'+_this.$route.params.userId,\r\n            }).then(function(res){\r\n                if (res.data.code == 200){\r\n                    const myData = res.data.data;\r\n                    _this.user = myData.user;\r\n                    _this.userList = myData.userList;\r\n                    _this.total = myData.total;\r\n\r\n                }else{\r\n                    _this.fail(res.data.msg)\r\n                }\r\n                console.log(res);\r\n            }).catch(function(error){\r\n                console.log(error);\r\n            });\r\n        },\r\n        data(){\r\n            return{\r\n                activeIndex: '2',\r\n                user:'',\r\n                userList:'',\r\n                currentPage:1,\r\n                pageSize:5,\r\n                total:0,\r\n                uploadPath:this.$axios.defaults.baseURL\r\n\r\n            }\r\n        },\r\n        methods: {\r\n            handleSelect(key, keyPath) {\r\n                console.log(key, keyPath);\r\n            },\r\n            fail(msg) {\r\n                this.$message.error(msg);\r\n            },\r\n            page(currentPage) {\r\n                const _this = this\r\n                _this.$axios.get(\"/followers/\"+_this.$route.params.userId+\"?currentPage=\" + currentPage).then(res => {\r\n                    const myData = res.data.data;\r\n                    _this.user = myData.user;\r\n                    _this.userList = myData.userList;\r\n                    _this.total = myData.total;\r\n                    _this.currentPage = res.data.data.currentPage\r\n\r\n                })\r\n            },\r\n            follow(entityId){\r\n                const _this = this;\r\n                //要先登录才能关注或取消关注\r\n                if (!this.$store.state.isLogin || this.$store.state.isLogin==''){\r\n                    this.$message.error('要登录才能关注哦');\r\n                    return;\r\n                }\r\n                let path = '';\r\n                if (_this.hasFollowed){\r\n                    path = '/unfollow'\r\n                }else {\r\n                    path = '/follow'\r\n                }\r\n                this.$axios({\r\n                    method:'post',\r\n                    url:path,\r\n                    data:{\r\n                        entityType:3,\r\n                        entityId:entityId\r\n                    }\r\n                }).then(function(res){\r\n                    if (res.data.code == 200){\r\n                        const myData = res.data.data;\r\n                        console.log(myData)\r\n                        _this.followerCount = myData.followerCount\r\n                        _this.hasFollowed = myData.hasFollowed\r\n\r\n                    }else{\r\n                        _this.fail(res.data.msg)\r\n                    }\r\n                    console.log(res);\r\n                }).catch(function(error){\r\n                    console.log(error);\r\n                });\r\n            }\r\n        }\r\n    }\r\n</script>\r\n\r\n<style scoped>\r\n    .navInfo{\r\n        float: right;\r\n        flex: auto;\r\n    }\r\n</style>"],"mappings":"AAmEA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;EACAG,QAAA;IAEA;IACA,MAAAC,KAAA;IACAC,OAAA,CAAAC,GAAA,MAAAC,MAAA,CAAAC,MAAA,CAAAC,GAAA;IACA;IACA,KAAAC,MAAA;MACAC,MAAA;MACAC,GAAA,kBAAAR,KAAA,CAAAG,MAAA,CAAAC,MAAA,CAAAK;IACA,GAAAC,IAAA,WAAAC,GAAA;MACA,IAAAA,GAAA,CAAAC,IAAA,CAAAC,IAAA;QACA,MAAAC,MAAA,GAAAH,GAAA,CAAAC,IAAA,CAAAA,IAAA;QACAZ,KAAA,CAAAe,IAAA,GAAAD,MAAA,CAAAC,IAAA;QACAf,KAAA,CAAAgB,QAAA,GAAAF,MAAA,CAAAE,QAAA;QACAhB,KAAA,CAAAiB,KAAA,GAAAH,MAAA,CAAAG,KAAA;MAEA;QACAjB,KAAA,CAAAkB,IAAA,CAAAP,GAAA,CAAAC,IAAA,CAAAO,GAAA;MACA;MACAlB,OAAA,CAAAC,GAAA,CAAAS,GAAA;IACA,GAAAS,KAAA,WAAAC,KAAA;MACApB,OAAA,CAAAC,GAAA,CAAAmB,KAAA;IACA;EACA;EACAT,KAAA;IACA;MACAU,WAAA;MACAP,IAAA;MACAC,QAAA;MACAO,WAAA;MACAC,QAAA;MACAP,KAAA;MACAQ,UAAA,OAAAnB,MAAA,CAAAoB,QAAA,CAAAC;IAEA;EACA;EACAC,OAAA;IACAC,aAAAC,GAAA,EAAAC,OAAA;MACA9B,OAAA,CAAAC,GAAA,CAAA4B,GAAA,EAAAC,OAAA;IACA;IACAb,KAAAC,GAAA;MACA,KAAAa,QAAA,CAAAX,KAAA,CAAAF,GAAA;IACA;IACAc,KAAAV,WAAA;MACA,MAAAvB,KAAA;MACAA,KAAA,CAAAM,MAAA,CAAA4B,GAAA,iBAAAlC,KAAA,CAAAG,MAAA,CAAAC,MAAA,CAAAK,MAAA,qBAAAc,WAAA,EAAAb,IAAA,CAAAC,GAAA;QACA,MAAAG,MAAA,GAAAH,GAAA,CAAAC,IAAA,CAAAA,IAAA;QACAZ,KAAA,CAAAe,IAAA,GAAAD,MAAA,CAAAC,IAAA;QACAf,KAAA,CAAAgB,QAAA,GAAAF,MAAA,CAAAE,QAAA;QACAhB,KAAA,CAAAiB,KAAA,GAAAH,MAAA,CAAAG,KAAA;QACAjB,KAAA,CAAAuB,WAAA,GAAAZ,GAAA,CAAAC,IAAA,CAAAA,IAAA,CAAAW,WAAA;MAEA;IACA;IACAY,OAAAC,QAAA;MACA,MAAApC,KAAA;MACA;MACA,UAAAqC,MAAA,CAAAC,KAAA,CAAAC,OAAA,SAAAF,MAAA,CAAAC,KAAA,CAAAC,OAAA;QACA,KAAAP,QAAA,CAAAX,KAAA;QACA;MACA;MACA,IAAAmB,IAAA;MACA,